# Required
SSH_PASSWORD=

# Optional
SSH_PORT=4444
SSH_USER=root
HOME=/app

# Public landing page (Railway HTTP domain should target this)
HTTP_PORT=8080
# PORT=8080
DEXSHELL_WWW=/opt/dexshell/www

